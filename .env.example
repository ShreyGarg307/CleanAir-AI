# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Map APIs Configuration
# React application requires this key injected through Vite define plugin.
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY_HERE"

# Data Provider APIs
VITE_GOV_DATA_AQI_API_KEY="YOUR_GOV_DATA_AQI_API_KEY_HERE"
VITE_OPENWEATHER_API_KEY="YOUR_OPENWEATHER_API_KEY_HERE"

# WhatsApp Cloud API
VITE_WHATSAPP_PHONE_NUMBER_ID="YOUR_WHATSAPP_PHONE_NUMBER_ID_HERE"
VITE_WHATSAPP_ACCESS_TOKEN="YOUR_WHATSAPP_ACCESS_TOKEN_HERE"